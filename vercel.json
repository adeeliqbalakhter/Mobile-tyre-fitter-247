{
  "outputDirectory": "dist",
  "framework": "vite",
  "cleanUrls": true,
  "redirects": [
    { "source": "/emergency-tyre-fitting", "destination": "/emergency-mobile-tyre-fitting", "permanent": true },
    { "source": "/24-hour-tyre-fitting", "destination": "/emergency-mobile-tyre-fitting", "permanent": true },
    { "source": "/same-day-tyre-fitting", "destination": "/emergency-mobile-tyre-fitting", "permanent": true },
    { "source": "/coverage/:slug", "destination": "/mobile-tyre-fitting-:slug", "permanent": true }
  ],
  "rewrites": [
    { "source": "/((?!.*\\.).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml; charset=utf-8" }]
    },
    {
      "source": "/robots.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
    },
    {
      "source": "/llms.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
    }
  ]
}
